# Server
PORT=3001
NODE_ENV=development

# Docker
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cpq_dev
DB_PORT=5432

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cpq_dev?schema=public"

# Auth
JWT_SECRET=<your-secret-here>
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12

# CORS
CLIENT_URL=http://localhost:5173